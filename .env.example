# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# Google Gemini API key (https://aistudio.google.com/apikey).
# NOTE: EXPO_PUBLIC_* variables are embedded in the app bundle and can be
# extracted from a shipped build. For production, proxy the Gemini call
# through a backend instead of shipping the key in the client.
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the Gemini model (defaults to gemini-flash-latest).
# EXPO_PUBLIC_GEMINI_MODEL=gemini-flash-latest
